# Application
NODE_ENV=development
PORT=4000
APP_NAME=tamcon-lottery
WEEKLY_DRAW_TIMEZONE=Africa/Addis_Ababa

# MongoDB — pick ONE approach:

# A) Full connection string (local or Atlas paste from Atlas UI)
# MONGODB_URI=mongodb://127.0.0.1:27017/tamcon_lottery
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/tamcon_lottery?retryWrites=true&w=majority

# B) Atlas split vars (host = substring after @ in the srv URI, before /database)
MONGODB_URI=
MONGODB_ATLAS_HOST=cluster0.YOUR_CLUSTER_REF.mongodb.net
MONGODB_ATLAS_USER=your_atlas_username
MONGODB_ATLAS_PASSWORD=your_atlas_password
MONGODB_ATLAS_DBNAME=tamcon_weekly_draw_lottery

# If Atlas still times out after whitelisting your IP: the app forces IPv4 for SRV (common macOS fix).
# Optional tunables (defaults are set in code if omitted):
# MONGODB_CONNECT_TIMEOUT_MS=60000
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=60000
# MONGODB_SOCKET_TIMEOUT_MS=120000
# MONGODB_FORCE_IPV4=true

# JWT (use long random strings in production)
JWT_ACCESS_SECRET=change_me_access_min_32_chars____________
JWT_REFRESH_SECRET=change_me_refresh_min_32_chars__________
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies (set false behind HTTPS-terminated proxy if needed)
COOKIE_SECURE=false
COOKIE_DOMAIN=

# CORS — comma-separated origins, no wildcards in production
ALLOWED_ORIGINS=http://localhost:3000

# OTP / mail
OTP_EXPIRES_MINUTES=5
# Development: leave MAIL_USER/MAIL_PASS empty — OTP prints in the terminal.
# Or set MAIL_LOG_OTP_TO_CONSOLE=true to force console OTP even with SMTP set.
MAIL_LOG_OTP_TO_CONSOLE=false
MAIL_HOST=smtp.ethereal.email
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Tamcon Lottery <noreply@example.com>"
# Production SMTP examples:
# Gmail: MAIL_HOST=smtp.gmail.com MAIL_PORT=587 MAIL_USER=you@gmail.com MAIL_PASS=<app-password>
# Ethereal (testing): create account at https://ethereal.email/create and paste user/pass here

# Chapa — https://developer.chapa.co/dashboard/quick-start
CHAPA_SECRET_KEY=CHASECK_TEST-your_secret_key
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-your_public_key
CHAPA_ENCRYPTION_KEY=your_encryption_key
CHAPA_BASE_URL=https://api.chapa.co/v1
# Dashboard → Webhooks tab (not the encryption key)
CHAPA_WEBHOOK_SECRET=
CHAPA_CALLBACK_URL=http://localhost:4000/api/v1/payments/chapa/callback

FRONTEND_URL=http://localhost:3000

# Lottery
TICKET_PRICE_ETB=10
PRIZE_POOL_PERCENT=0.53
TICKET_NUMBER_DIGITS=8
